{
  "name": "wealthfolio-addons",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "workspaces": [
    "official/*"
  ],
  "scripts": {
    "build:official": "pnpm -r --filter './official/*' build",
    "bundle:official": "pnpm -r --filter './official/*' bundle",
    "type-check:official": "pnpm -r --filter './official/*' type-check",
    "validate:addons": "node scripts/validate-addons.mjs",
    "generate:readme": "node scripts/generate-readme.mjs",
    "generate": "pnpm generate:readme",
    "check": "pnpm validate:addons && pnpm type-check:official"
  }
}
